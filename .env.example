# ─── Server runtime ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/marketing_platform

# ─── Public URL (used for Google OAuth callback + frontend redirects) ────────
# Full URL with scheme. Should match the domain users access in the browser.
PUBLIC_URL=https://your-domain.com

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (full URLs).
# If frontend and API are served on the same domain via reverse proxy, this can be left empty.
# Use "*" to allow any origin (NOT recommended for production).
ALLOWED_ORIGINS=https://your-domain.com

# ─── AI providers ────────────────────────────────────────────────────────────
# Gemini (Google AI Studio): https://aistudio.google.com/apikey
AI_INTEGRATIONS_GEMINI_API_KEY=
# Optional override; leave empty to use Google's default endpoint
AI_INTEGRATIONS_GEMINI_BASE_URL=

# Anthropic Claude: https://console.anthropic.com/
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# OpenAI (GPT-4o for Messenger booking + content pipeline): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Grok (trend analysis): https://console.x.ai/
GROK_API_KEY=

# ─── Optional integrations ───────────────────────────────────────────────────
# Metricool publishing webhook
METRICOOL_WEBHOOK_URL=

# Make.com automation webhook
MAKE_WEBHOOK_URL=

# ─── Phase 5a: Weekly Trend Digest delivery (pick one) ────────────────────────
# Option A — direct Telegram bot. Create via @BotFather, add to a group/chat,
# get the chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Option B — let MAKE_WEBHOOK_URL above route the message instead. The dispatcher
# will POST { event_type: "weekly_trend_digest", text, data } so your Make
# scenario can fan out to Telegram / email / Slack however you want.

# Set to "1" to skip cron registration in this process (e.g. for a worker
# split-out where one node-process handles the scheduler and others don't).
SCHEDULER_DISABLED=

# Google OAuth (for Google Business / Reviews integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Frontend build ──────────────────────────────────────────────────────────
# Base path for the SPA (defaults to "/")
BASE_PATH=/

# Mẫu biến môi trường production cho api-server.
# Trên VPS: copy thành deploy/.env.production rồi điền giá trị thật.
# KHÔNG commit file .env.production (đã được .gitignore).

# Cổng API server lắng nghe (nginx proxy /api sang cổng này)
PORT=3001

# Postgres
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/marketing_plan

# Phiên đăng nhập + tài khoản admin
SESSION_SECRET=đổi-thành-chuỗi-ngẫu-nhiên-dài
ADMIN_PASSWORD=đổi-mật-khẩu

# Anthropic (Claude)
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=

# Gemini
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
AI_INTEGRATIONS_GEMINI_API_KEY=

# OpenAI (GPT) — Agent 4 prompt ảnh + automation runner
OPENAI_API_KEY=

# Google Places/Maps (tùy chọn — Market Research)
GOOGLE_API_KEY=

# Meta (Facebook/Instagram) — BẮT BUỘC nếu mở webhook /api/messenger/webhook.
# App Secret từ developers.facebook.com → App → Settings → Basic (verify HMAC X-Hub-Signature-256).
META_APP_SECRET=

# CORS — domain frontend gọi API (vd: https://app.example.com).
# Nếu nginx proxy cùng domain thì có thể bỏ trống.
ALLOWED_ORIGINS=

# Webhook ra ngoài (tùy chọn — gửi digest/automation tới URL bất kỳ)
OUTBOUND_WEBHOOK_URL=

# Telegram (tùy chọn — nhận digest tuần)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
